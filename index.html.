  <script>
    const root = document.documentElement;
    let currentX = 0;
    let currentY = 0;
    let targetX = 0;
    let targetY = 0;
    let currentScale = 1;
    let targetScale = 1;
    let currentSpread = 0;
    let targetSpread = 0;
    let currentBlurSm = 0;
    let targetBlurSm = 0;
    let currentBlurMd = 0;
    let targetBlurMd = 0;

    function tick() {
      currentX += (targetX - currentX) * 0.09;
      currentY += (targetY - currentY) * 0.09;
      currentScale += (targetScale - currentScale) * 0.08;
      currentSpread += (targetSpread - currentSpread) * 0.08;
      currentBlurSm += (targetBlurSm - currentBlurSm) * 0.08;
      currentBlurMd += (targetBlurMd - currentBlurMd) * 0.08;

      root.style.setProperty('--mx', `${currentX.toFixed(2)}px`);
      root.style.setProperty('--my', `${currentY.toFixed(2)}px`);
      root.style.setProperty('--scale', currentScale.toFixed(4));
      root.style.setProperty('--spread', `${currentSpread.toFixed(2)}px`);
      root.style.setProperty('--blur-sm', `${currentBlurSm.toFixed(2)}px`);
      root.style.setProperty('--blur-md', `${currentBlurMd.toFixed(2)}px`);
      root.style.setProperty('--tiltX', `${(-currentY * 0.05).toFixed(2)}deg`);
      root.style.setProperty('--tiltY', `${(currentX * 0.05).toFixed(2)}deg`);

      requestAnimationFrame(tick);
    }

    function updateByPointer(x, y) {
      const xRatio = (x / window.innerWidth - 0.5) * 2;
      const yRatio = (y / window.innerHeight - 0.5) * 2;
      const absX = Math.abs(xRatio);

      targetX = xRatio * 26;
      targetY = yRatio * 18;

      const centerStrength = 1 - Math.min(1, absX);
      targetScale = 1 + centerStrength * 0.05;
      targetSpread = xRatio * 18;
      targetBlurSm = absX * 0.6;
      targetBlurMd = absX * 1.1;
    }

    window.addEventListener('mousemove', (event) => {
      updateByPointer(event.clientX, event.clientY);
    });

    window.addEventListener('touchmove', (event) => {
      const touch = event.touches[0];
      if (!touch) return;
      updateByPointer(touch.clientX, touch.clientY);
    }, { passive: true });

    window.addEventListener('mouseleave', () => {
      targetX = 0;
      targetY = 0;
      targetScale = 1;
      targetSpread = 0;
      targetBlurSm = 0;
      targetBlurMd = 0;
    });


    const revealTargets = document.querySelectorAll('.section, .card, .timeline-item, .mini-block');
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });

      revealTargets.forEach((el) => {
        if (!el.closest('.hero')) {
          el.classList.add('reveal');
          observer.observe(el);
        }
      });
    }

    tick();
  </script>
